* Asset utilization channel
reghdfe turnover_rate_w c.gov_c##i.treated##i.post ///
    l.revenue_growth_w l.size l.nwc_w ///
    if inrange(year,2014,2019), absorb(firm_id year) vce(cluster firm_id)
estadd local firmfe "\checkmark" 
estadd local yearfe "\checkmark" 
