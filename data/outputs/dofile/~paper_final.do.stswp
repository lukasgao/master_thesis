***************************************************************
use "did_data_1pct.dta", clear 

clear
tempfile results
save `results', emptyok

forvalues t = 1/10 {

    use did_data_`t'pct.dta, clear

    xtset firm_id year

    winsor2 roa roe tobinq revenue_growth debt_ratio nwc turnover_rate capex_ratio manage_exp_ratio, cut(2.5 97.5)

    gen gov_lag = l.gov_score
    summ gov_lag if inrange(year,2014,2019), meanonly
    gen gov_c = gov_lag - r(mean)

    reghdfe roa_w ///
        c.gov_c##i.treated##i.post ///
        l.revenue_growth_w l.size l.debt_ratio_w l.nwc_w l.capex_ratio_w ///
        if inrange(year,2014,2019), ///
        absorb(firm_id year) vce(cluster firm_id)

    * 核心系数和标准误
    scalar beta_val = _b[c.gov_c#1.treated#1.post]
    scalar se_val   = _se[c.gov_c#1.treated#1.post]

    * p-value
    scalar t_stat = beta_val / se_val
    scalar p_val  = 2 * ttail(e(df_r), abs(t_stat))

    * treated × post 系数（如果你也想报）
    scalar tp_val = _b[1.treated#1.post]

    * 样本量和R2
    scalar N_val     = e(N)
    scalar r2a_val   = e(r2_a)

    * treated firms 数量
    quietly levelsof firm_id if treated == 1 & inrange(year,2014,2019), local(treated_ids)
    local n_treated : word count `treated_ids'
    scalar treated_n = `n_treated'

    clear
    set obs 1

    gen threshold     = `t'
    gen beta          = beta_val
    gen se            = se_val
    gen p_value       = p_val
    gen treated_post  = tp_val
    gen obs           = N_val
    gen adj_r2        = r2a_val
    gen treated_firms = treated_n

    append using `results'
    save `results', replace
}

use `results', clear
sort threshold


gen upper95 = beta + 1.96*se
gen lower95 = beta - 1.96*se

twoway ///
    (rcap upper95 lower95 threshold, lcolor(gs8) lwidth(medium)) ///
    (connected beta threshold, lcolor(navy) mcolor(navy) msymbol(O) ///
        msize(medium) lwidth(medium)), ///
    yline(0, lcolor(maroon) lpattern(dash) lwidth(medium)) ///
    xlabel(1(1)10, labsize(small)) ///
    xtitle("Treatment threshold (%)", size(medsmall)) ///
    ytitle("Coefficient on Treated × Post × Governance", size(medsmall)) ///
    title("Robustness to Alternative Treatment Thresholds", size(medium)) ///
    legend(off) ///
    graphregion(color(white)) ///
    plotregion(color(white)) ///
    bgcolor(white)


