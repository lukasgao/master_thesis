******************************
* placebo tests
******************************
use "did_data_2pct.dta", clear 
xtset firm_id year
winsor2 roa roe tobinq revenue_growth debt_ratio nwc turnover_rate capex_ratio manage_exp_ratio,cut(2.5, 97.5) 
gen gov_lag = l.gov_score
summ gov_lag if year < 2018, meanonly
gen gov_c = gov_lag - r(mean)

gen post_placebo = (year >= 2016) if year < 2018

est clear  
reghdfe roa_w  i.treated##i.post_placebo year if year < 2018, absorb(firm_id year) vce(cluster firm_id)
estadd local firmfe "\checkmark" 
estadd local yearfe "\checkmark" 
est store m1

reghdfe roa_w c.gov_c##i.treated##i.post_placebo if year < 2018, absorb(firm_id year) vce(cluster firm_id)
estadd local firmfe "\checkmark" 
estadd local yearfe "\checkmark" 
est store m2

reghdfe roa_w c.gov_c##i.treated##i.post_placebo l.revenue_growth_w l.size l.debt_ratio_w l.nwc_w l.capex_ratio_w if year < 2018, absorb(firm_id year) vce(cluster firm_id)
estadd local firmfe "\checkmark" 
estadd local yearfe "\checkmark" 
est store m3

