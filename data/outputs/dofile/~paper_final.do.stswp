***************************************************
*分组回归
***************************************************
est clear

bysort year: egen median_gov = median(gov_lag)
gen gov_high = (gov_lag >= median_gov)
xtset firm_id year


reghdfe turnover_rate_w i.treated##i.post l.revenue_growth_w l.size l.debt_ratio_w l.nwc_w l.capex_ratio_w if gov_high==0 & inrange(year,2014,2019), absorb(firm_id year) vce(cluster firm_id)
estadd local firmfe "\checkmark" 
estadd local yearfe "\checkmark" 
est store m1


reghdfe turnover_rate_w i.treated##i.post l.revenue_growth_w l.size l.debt_ratio_w l.nwc_w l.capex_ratio_w if gov_high==1 & inrange(year,2014,2019), absorb(firm_id year) vce(cluster firm_id)
estadd local firmfe "\checkmark" 
estadd local yearfe "\checkmark" 
est store m2

esttab m1 m2  using "/Users/hengdegao/python/thesis/data/outputs/tables/turnover_rate_regression.tex", replace ///
    mgroups("Dependent variable:", pattern(1 0 0 0) span prefix(\multicolumn{@span}{c}{) suffix(}) ) ///
    mtitles("low corporate governance" "high corporate governance") ///
    cells(b(fmt(3) star) t(par fmt(3))) ///
    booktabs ///
    keep(1.treated#1.post gov_lag ///
         L.size  L.nwc_w L.revenue_growth_w _cons) ///
    order(gov_lag 1.treated#1.post  ///
          L.size  L.nwc_w L.revenue_growth_w  _cons) ///
    coeflabels(1.treated#1.post "treated  ×  post" ///
               gov_lag "L.gov_score" ///
               L.size "L.size" ///
               L.debt_ratio_w "L.debt_ratio_w" ///
               L.nwc_w "L.nwc_w" ///
               L.revenue_growth_w "L.revenue_growth_w" ///
               L.capex_ratio_w "L.capex_ratio_w") ///
    stats(N r2_a firmfe yearfe, labels("Observations" "Adjusted R-squared" "Firm FE" "Year FE")) ///
    star(* 0.10 ** 0.05 *** 0.01) ///
    nogaps compress ///
