use "did_data_2pct.dta", clear 
xtset firm_id year
*gen ln_ev = ln(ev)
*winsor2 ln_ev, cut(2.5 97.5)


winsor2 roa roe tobinq revenue_growth debt_ratio nwc turnover_rate capex_ratio manage_exp_ratio,cut(2.5, 97.5) 
gen gov_lag = l.gov_score
summ gov_lag if inrange(year, 2014, 2019), meanonly
gen gov_c = gov_lag - r(mean)

reghdfe roa_w c.gov_c##i.treated##i.post  l.revenue_growth_w l.size l.debt_ratio_w l.nwc_w l.capex_ratio_w if inrange(year, 2014, 2019), absorb(firm_id year) vce(cluster firm_id)

******************************
***  statistics summary  ***
******************************
est clear
estpost tabstat roa_w gov_score capex_ratio_w revenue_growth_w size debt_ratio_w nwc_w ///
    if inrange(year, 2014, 2019), ///
    statistics(mean sd p50 min max count) columns(statistics)
	
esttab using "/Users/hengdegao/python/thesis/data/outputs/tables/main_regression.tex", replace ///
    cells("mean(fmt(%9.2f)) sd(fmt(%9.2f)) p50(fmt(%9.2f)) min(fmt(%9.2f)) max(fmt(%9.2f)) count(fmt(%9.0f))") ///
    nonumber nomtitle nonote noobs label booktabs ///
    collabels("Mean" "SD" "Median" "Min" "Max" "N")
	

*******************************
***  t-test  ***
*******************************
est clear

estpost ttest roa_w gov_score size revenue_growth_w capex_ratio_w debt_ratio_w nwc_w if inrange(year, 2014, 2019) , by(treated) unequal

esttab using "/Users/hengdegao/python/thesis/data/outputs/tables/ttest.tex", replace ///
	cells("mu_2(fmt(4)) mu_1(fmt(4)) b(fmt(4)) t(fmt(2)) p(fmt(3))") ///
    collabels("Treatment Mean" "Control Mean" "Difference" "T-stat" "P-value") ///
    nonumber noobs label
*******************************
***  parallel trends test ***
*******************************
gen relative_year = year - 2018
tab relative_year, gen(D)
rename D2 pre_4  
rename D3 pre_3  
rename D4 pre_2  
rename D5 pre_1  
rename D6 post_0 
rename D7 post_1 

***********test pre_4 pre_3 pre_2

global event_dummies "pre_4 pre_3 pre_2 post_0 post_1"

foreach var of varlist $event_dummies {
    gen `var'_treated = `var' * treated
}

reghdfe roa_w pre_4_treated pre_3_treated pre_2_treated post_0_treated post_1_treated L.(size gov_score revenue_growth_w debt_ratio_w nwc_w), absorb(firm_id year) vce(cluster firm_id)

coefplot, keep(*_treated) vertical yline(0) ci(95)   ytitle("Coefficient on Treated x Year") xtitle("Years Relative to Trade War Shock") coeflabels(pre_4_treated = "-4" pre_3_treated = "-3" pre_2_treated = "-2" post_0_treated = "0" post_1_treated = "1") graphregion(fcolor(white)) addplot(line @b @at, lcolor(gs1) ) ciopts(lpattern(dash) recast(rcap) msize(medium))  


	
*******************************
***   regression  ****
*******************************

******* main regression  *****
est clear  
reghdfe roa_w  i.treated##i.post  if inrange(year, 2014, 2019), absorb(firm_id year) vce(cluster firm_id)
estadd local firmfe "\checkmark" 
estadd local yearfe "\checkmark" 
est store m1

reghdfe roa_w c.gov_c##i.treated##i.post if inrange(year, 2014, 2019), absorb(firm_id year) vce(cluster firm_id)
estadd local firmfe "\checkmark" 
estadd local yearfe "\checkmark" 
est store m2

reghdfe roa_w c.gov_c##i.treated##i.post l.revenue_growth_w l.size l.debt_ratio_w l.nwc_w l.capex_ratio_w if inrange(year, 2014, 2019), absorb(firm_id year) vce(cluster firm_id)
estadd local firmfe "\checkmark" 
estadd local yearfe "\checkmark" 
est store m3

esttab m1 m2 m3  using "/Users/hengdegao/python/thesis/data/outputs/tables/main_regression.tex", replace ///
	collabels(none) ///
    cells(b(fmt(3) star) t(par fmt(3))) ///
    booktabs  ///
    keep(1.treated#1.post gov_c 1.treated#1.post#c.gov_c ///
         L.size L.debt_ratio_w L.nwc_w L.revenue_growth_w L.capex_ratio_w _cons) ///
    order(1.treated#1.post gov_c 1.treated#1.post#c.gov_c ///
          L.size L.debt_ratio_w L.nwc_w L.revenue_growth_w L.capex_ratio_w _cons) ///
    coeflabels(1.treated#1.post "treated × post" ///
               gov_c "L.centered_gov_score" ///
               1.treated#1.post#c.gov_c "treated × post × centered_gov_score" ///
               L.size "L.size" ///
               L.debt_ratio_w "L.debt_ratio_w" ///
               L.nwc_w "L.nwc_w" ///
               L.revenue_growth_w "L.revenue_growth_w" ///
               L.capex_ratio_w "L.capex_ratio_w") ///
    stats(N r2_a firmfe yearfe, labels("Observations" "Adjusted R-squared" "Firm FE" "Year FE")) ///
    label star(* 0.10 ** 0.05 *** 0.01) ///
    nogaps compress ///
    alignment(D{.}{.}{-1})
	

